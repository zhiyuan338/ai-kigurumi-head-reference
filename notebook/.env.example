# --- Image generation (GPT-Image-2 via OpenAI-compatible endpoint) ---
IMAGE_API_KEY=sk-replace-me
IMAGE_BASE_URL=https://api.openai.com/v1
IMAGE_MODEL=gpt-image-2
IMAGE_SIZE=1024x1024
IMAGE_QUALITY=high
IMAGE_N=2

# --- Reasoning / vision (Qwen3.5-VL via Aliyun Dashscope compat) ---
REASON_API_KEY=sk-replace-me
REASON_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
REASON_MODEL=qwen-vl-max-latest

# --- Agent behavior ---
MAX_REFINE=2
SIMILAR_TOP_K=2
